{
    "name": "runopencode/stream",
    "description": "A small library implementing StreamInterface from PSR-7.",
    "license": "MIT",
    "authors": [
        {
            "name": "Nikola Svitlica a.k.a TheCelavi",
            "email": "thecelavi@runopencode.com"
        }
    ],
    "require": {
        "php": ">=8.4",
        "psr/http-message": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "RunOpenCode\\Component\\Stream\\": "src"
        },
        "files": [
            "src/functions.php"
        ]
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../Component/Logger",
            "options": {
                "symlink": false
            }
        },
        {
            "type": "path",
            "url": "../../Component/Dataset",
            "options": {
                "symlink": false
            }
        },
        {
            "type": "path",
            "url": "../../Component/Bitmask",
            "options": {
                "symlink": false
            }
        },
        {
            "type": "path",
            "url": "../../Component/Metadata",
            "options": {
                "symlink": false
            }
        },
        {
            "type": "path",
            "url": "../../Bundle/MetadataBundle",
            "options": {
                "symlink": false
            }
        },
        {
            "type": "path",
            "url": "../../Bundle/QueryBundle",
            "options": {
                "symlink": false
            }
        },
        {
            "type": "path",
            "url": "../../Bundle/LoggerBundle",
            "options": {
                "symlink": false
            }
        }
    ],
    "config": {
        "sort-packages": true
    },
    "version": "0.2",
    "minimum-stability": "dev",
    "prefer-stable": true
}
